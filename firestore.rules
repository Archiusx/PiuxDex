rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // -- HARDENED HELPERS --
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Auth Check for Admin (Now via PIN-verified Admin Document)
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // -- SCHEMAS --
    function isValidSubject(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.code is string && data.code.size() <= 20 &&
             data.color is string && data.color.size() <= 10 &&
             data.syllabus is list && data.syllabus.size() <= 60;
    }

    function isValidUserSubject(data) {
      return isValidSubject(data) && 
             data.userId == request.auth.uid;
    }
    
    function isValidTask(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.priority in ['low', 'medium', 'high'] &&
             data.ownerId == request.auth.uid;
    }

    function isValidResource(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.type in ['pdf', 'pptx', 'c', 'algo', 'other'] &&
             data.url is string && data.url.size() <= 500 &&
             data.creatorId == request.auth.uid;
    }

    function isValidClipboard(data) {
      return data.content is string && data.content.size() <= 20000;
    }

    // -- COLLECTIONS --

    match /test/connection {
      allow read: if true;
    }

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidSubject(incoming()) && isValidId(subjectId);
    }

    match /userSubjects/{uSubId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid) && isValidId(uSubId);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                       (incoming().userId == request.auth.uid);
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid && isValidId(taskId);
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && 
                       incoming().ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /resources/{resourceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().creatorId == request.auth.uid && isValidId(resourceId);
      allow update: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isAdmin()) && 
                       incoming().creatorId == existing().creatorId;
      allow delete: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    match /clipboard/global {
      allow read: if isSignedIn();
      allow update, create: if isSignedIn() && isValidClipboard(incoming());
    }

    match /clipboard_stream/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
    }
    
    // Admin list setup (Unlockable via PIN 9763)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && adminId == request.auth.uid && incoming().pin == '9763';
      allow delete: if isSignedIn() && adminId == request.auth.uid;
    }
  }
}
